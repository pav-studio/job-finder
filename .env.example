# .env

# ======================================================
# EMAIL / SMTP
# ======================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_16_char_app_password
FROM_EMAIL=yourgmail@gmail.com

# ======================================================
# APP SETTINGS
# ======================================================

DAILY_SEND_LIMIT=10
WAIT_SECONDS=90
DB_FILE=jobs.db
RESUME_FILE=resume.pdf
TEMPLATE_FILE=mail.json

# ======================================================
# JOB SEARCH API KEYS (OPTIONAL)
# ======================================================

RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=jsearch.p.rapidapi.com
LINKEDIN_API_HOST=linkedin-data-api.p.rapidapi.com

# ======================================================
# USER PROFILE
# ======================================================

FULL_NAME=John Doe
PHONE=+0000000000
EMAIL=youremail.com
LOCATION=Your location
GITHUB=https://github.com/ptsdpatient
LINKEDIN=https://linkedin.com/in/your-real-profile

# ======================================================
# SEARCH SETTINGS
# ======================================================

COUNTRY=XX
REMOTE_ONLY=true